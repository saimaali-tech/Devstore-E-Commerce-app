# PostgreSQL (local or Docker)
DATABASE_URL=postgresql://devstore:devstore@localhost:5432/devstore

# Browser → API (local split ports). Leave empty when using same-origin /api (Kubernetes Ingress).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Feature tier for UI + gated API routes (v1 | v2 | v3)
APP_RELEASE=v3
NEXT_PUBLIC_APP_RELEASE=v3

# API CORS (comma-separated origins, or * for dev only)
WEB_ORIGINS=http://localhost:3000
